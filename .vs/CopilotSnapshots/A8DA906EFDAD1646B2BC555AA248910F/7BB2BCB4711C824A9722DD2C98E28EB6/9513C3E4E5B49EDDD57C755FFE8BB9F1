<%@ Page Title="About | KUET Career Club" Language="C#" MasterPageFile="~/Site.Master" AutoEventWireup="true" CodeBehind="About.aspx.cs" Inherits="WebLab.WebForms.AboutPage" %>
<asp:Content ID="HeadContent" ContentPlaceHolderID="HeadContent" runat="server">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css" />
    <style>
    :root[data-theme="dark"] {
      --bg: #0d0d0d; --bg2: #111; --card: #161616;
      --text: #fff; --text-muted: rgba(255,255,255,0.55);
      --text-faint: rgba(255,255,255,0.4);
      --border: rgba(255,255,255,0.08);
      --border-nav: rgba(255,255,255,0.12);
      --nav-bg: rgba(255,255,255,0.07);
      --copyright: rgba(255,255,255,0.2);
    }
    :root[data-theme="light"] {
      --bg: #f5f5f5; --bg2: #ebebeb; --card: #fff;
      --text: #0a0a0a; --text-muted: rgba(0,0,0,0.6);
      --text-faint: rgba(0,0,0,0.45);
      --border: rgba(0,0,0,0.08);
      --border-nav: rgba(0,0,0,0.12);
      --nav-bg: rgba(0,0,0,0.06);
      --copyright: rgba(0,0,0,0.3);
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', sans-serif; background: var(--bg); color: var(--text); transition: background 0.3s, color 0.3s; }

    .nav { display: flex; align-items: center; justify-content: space-between; padding: 1.2rem 2.5rem; z-index: 10; position: relative; }
    .nav-brand { display: flex; align-items: center; gap: 10px; font-size: 15px; font-weight: 700; letter-spacing: 0.08em; color: var(--text); text-decoration: none; }
    .nav-brand img { width: 40px; height: 40px; border-radius: 50%; object-fit: cover; border: 2px solid #1a7a6e; }
    .nav-links-pill { display: flex; align-items: center; background: var(--nav-bg); border: 0.5px solid var(--border-nav); border-radius: 30px; padding: 6px 8px; gap: 4px; }
    .nav-links-pill a { color: var(--text-faint); text-decoration: none; font-size: 13px; padding: 6px 18px; border-radius: 20px; letter-spacing: 0.05em; transition: color 0.2s; }
    .nav-links-pill a.active { color: #1a7a6e; font-weight: 700; border-bottom: 2px solid #1a7a6e; border-radius: 0; }
    .nav-links-pill a:hover { color: var(--text); }
    .theme-toggle { width: 42px; height: 42px; border-radius: 50%; border: 1px solid var(--border-nav); background: var(--nav-bg); display: flex; align-items: center; justify-content: center; cursor: pointer; font-size: 20px; transition: all 0.2s; }
    .theme-toggle:hover { border-color: #1a7a6e; transform: scale(1.1); }

    /* PAGE HEADER */
    .page-header {
      padding: 4rem 2.5rem 3rem;
      position: relative;
      overflow: hidden;
    }
    .page-header::before {
      content: '';
      position: absolute;
      left: -100px; top: -100px;
      width: 400px; height: 400px;
      background: radial-gradient(circle, rgba(26,122,110,0.15) 0%, transparent 70%);
      pointer-events: none;
    }
    .page-tag { font-size: 12px; color: #1a7a6e; letter-spacing: 0.1em; font-weight: 700; margin-bottom: 12px; }
    .page-header h1 { font-size: 48px; font-weight: 700; line-height: 1.1; color: var(--text); margin-bottom: 1rem; }
    .page-header p { font-size: 16px; color: var(--text-muted); max-width: 540px; line-height: 1.7; }
    .header-divider { width: 60px; height: 2px; background: #1a7a6e; margin: 1.5rem 0; }

    /* ABOUT CARDS */
    .about-section { padding: 0 2.5rem 4rem; }
    .about-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 16px; }
    .about-card {
      background: var(--card);
      border: 0.5px solid var(--border);
      border-radius: 12px;
      padding: 2rem;
      transition: border-color 0.2s;
    }
    .about-card:hover { border-color: rgba(26,122,110,0.4); }
    .card-icon { font-size: 28px; margin-bottom: 1rem; }
    .about-card h2 { font-size: 17px; font-weight: 700; color: var(--text); margin-bottom: 10px; }
    .about-card p { font-size: 14px; color: var(--text-muted); line-height: 1.7; }
    .about-card ul { list-style: none; padding: 0; }
    .about-card ul li { font-size: 14px; color: var(--text-muted); padding: 5px 0; display: flex; align-items: center; gap: 8px; }
    .about-card ul li::before { content: '→'; color: #1a7a6e; font-size: 13px; }

    /* FOOTER */
    .footer-tagline { padding: 2rem 2.5rem 1.5rem; border-top: 0.5px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
    .footer-tagline h2 { font-size: 28px; font-weight: 700; color: var(--text); }
    .footer-tagline h2 em { font-style: italic; color: #1a7a6e; }
    .social-links { display: flex; gap: 16px; }
    .social-links a { color: var(--text-faint); text-decoration: none; font-size: 22px; transition: color 0.2s; }
    .social-links a:hover { color: #1a7a6e; }
    .copyright { text-align: right; padding: 0 2.5rem 1.5rem; font-size: 12px; color: var(--copyright); letter-spacing: 0.04em; }
    </style>
</asp:Content>
<asp:Content ID="TitleContent" ContentPlaceHolderID="TitleContent" runat="server">About | KUET Career Club</asp:Content>
<asp:Content ID="MainContent" ContentPlaceHolderID="MainContent" runat="server">
  <nav class="nav" role="navigation" aria-label="Main navigation">
    <a class="nav-brand" href="~/">
      <img src="/assets/logo.png" alt="KUET Career Club" />
      KUET CAREER CLUB
    </a>
    <div class="nav-links-pill" role="menubar">
      <a href="~/Default.aspx" role="menuitem">Home</a>
      <a href="~/About.aspx" role="menuitem" class="active">About</a>
      <a href="~/Events.aspx" role="menuitem">Events</a>
    </div>
    <button type="button" class="theme-toggle" id="themeToggle" aria-label="Toggle theme">🌓</button>
  </nav>

  <section class="page-header">
    <div class="page-tag">WHO WE ARE</div>
    <h1>About KUET<br>Career Club</h1>
    <div class="header-divider"></div>
    <p>We are a student-led platform helping KUET students prepare for meaningful careers with confidence and direction.</p>
  </section>

  <section class="about-section">
    <div class="about-grid">
      <article class="about-card">
        <div class="card-icon">🎯</div>
        <h2>Our Mission</h2>
        <p>To bridge the gap between academic learning and professional success by creating practical, inclusive, and growth-focused experiences.</p>
      </article>
      <article class="about-card">
        <div class="card-icon">🔭</div>
        <h2>Our Vision</h2>
        <p>To develop a vibrant career ecosystem where every KUET student can explore potential, sharpen skills, and lead with impact.</p>
      </article>
      <article class="about-card">
        <div class="card-icon">⚡</div>
        <h2>What We Do</h2>
        <ul>
          <li>Career guidance workshops</li>
          <li>Resume and interview preparation</li>
          <li>Industry and alumni networking</li>
          <li>Leadership and team projects</li>
        </ul>
      </article>
    </div>
  </section>

  <div class="footer-tagline">
    <h2>Stay ahead of the <em>curve.</em></h2>
    <div class="social-links">
      <a href="https://www.facebook.com/kuetcareerclub/" target="_blank" rel="noopener noreferrer"><i class="ti ti-brand-facebook"></i></a>
      <a href="https://www.linkedin.com/company/kuetcareerclub/" target="_blank" rel="noopener noreferrer"><i class="ti ti-brand-linkedin"></i></a>
    </div>
  </div>
  <div class="copyright">© 2026 KUET CAREER CLUB. ALL RIGHTS RESERVED.</div>

  <script type="text/javascript">
    (function () {
      // Theme toggle (stores preference in localStorage)
      var btn = document.getElementById('themeToggle');
      var root = document.documentElement;
      var stored = localStorage.getItem('site-theme');
      if (stored) root.setAttribute('data-theme', stored);
      btn && btn.addEventListener('click', function () {
        var next = (root.getAttribute('data-theme') === 'dark') ? 'light' : 'dark';
        root.setAttribute('data-theme', next);
        localStorage.setItem('site-theme', next);
      });

      // Mark current nav link active (works with master page routing)
      try {
        var links = document.querySelectorAll('.nav-links-pill a');
        var path = location.pathname.replace(/\/$/, '').toLowerCase();
        links.forEach(function (a) {
          var href = a.getAttribute('href') || '';
          if (href && path.indexOf(href.replace(/~\//, '/').replace(/^\//, '').toLowerCase()) !== -1) {
            a.classList.add('active');
          }
        });
      } catch (e) { /* no-op */ }
    })();
  </script>
</asp:Content>
