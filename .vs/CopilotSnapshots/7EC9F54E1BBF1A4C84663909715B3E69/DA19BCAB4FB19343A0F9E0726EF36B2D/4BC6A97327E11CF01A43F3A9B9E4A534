<%@ Master Language="C#" AutoEventWireup="true" %>
<!DOCTYPE html>
<html lang="en">
<head runat="server">
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><asp:ContentPlaceHolder ID="TitleContent" runat="server">KUET Career Club</asp:ContentPlaceHolder></title>
    <link rel="stylesheet" href="~/Site.css" runat="server"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css" />
    <asp:ContentPlaceHolder ID="HeadContent" runat="server" />
</head>
<body>
    <a class="skip-link" href="#maincontent">Skip to main content</a>
    <form id="form1" runat="server">
    <nav class="nav">
            <a runat="server" href="~/Default.aspx" class="nav-brand">
                <asp:Image ID="NavLogo" runat="server" ImageUrl="~/kcc-logo.png" AlternateText="KCC Logo" Style="height:44px;width:auto;border-radius:6px;object-fit:contain;border:2px solid #1a7a6e;margin-right:12px;vertical-align:middle;background:transparent;padding:4px;" />
                <span style="vertical-align:middle;font-weight:700;letter-spacing:0.06em;color:inherit;text-decoration:none;">KUET CAREER CLUB</span>
            </a>
            <div class="nav-links-pill">
                <asp:HyperLink ID="HomeLink" runat="server" NavigateUrl="~/Default.aspx" Text="HOME" CssClass="" />
                <asp:HyperLink ID="AboutLink" runat="server" NavigateUrl="~/About.aspx" Text="ABOUT" CssClass="" />
                <asp:HyperLink ID="EventsLink" runat="server" NavigateUrl="~/Events.aspx" Text="EVENTS" CssClass="" />
                <asp:HyperLink ID="MembersLink" runat="server" NavigateUrl="~/Members.aspx" Text="MEMBERS" CssClass="" />
                <asp:HyperLink ID="ContactLink" runat="server" NavigateUrl="~/Contact.aspx" Text="CONTACT" CssClass="" />
            </div>
            <button type="button" class="theme-toggle" id="themeToggle" aria-label="Toggle dark/light theme">🌙</button>
        </nav>
        <script type="text/javascript">
            (function(){
                var html = document.documentElement;
                var btn = document.getElementById('themeToggle');
                // initialize theme from localStorage or default to dark
                var theme = localStorage.getItem('kcc_theme') || 'dark';
                html.setAttribute('data-theme', theme);
                if(btn){ btn.textContent = (theme === 'dark') ? '🌙' : '☀️'; }
                // attach click handler to toggle and persist
                if(btn){ btn.addEventListener('click', function(){
                    var cur = html.getAttribute('data-theme');
                    var next = (cur === 'dark') ? 'light' : 'dark';
                    html.setAttribute('data-theme', next);
                    localStorage.setItem('kcc_theme', next);
                    btn.textContent = (next === 'dark') ? '🌙' : '☀️';
                }); }
            })();
        </script>

        <main id="maincontent" class="page-content">
            <asp:ContentPlaceHolder ID="MainContent" runat="server" />
        </main>

        <footer class="site-footer">
            <p>© 2026 KUET Career Club. Empowering students for professional excellence.</p>
        </footer>
    </form>
</body>
</html>