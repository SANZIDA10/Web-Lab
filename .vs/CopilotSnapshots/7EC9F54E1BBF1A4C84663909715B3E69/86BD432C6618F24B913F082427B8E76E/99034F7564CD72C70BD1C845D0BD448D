:root {
    --bg-primary: linear-gradient(135deg, #071b3a, #1b6cff);
    --bg-secondary: rgba(255, 255, 255, 0.06);
    --bg-tertiary: rgba(10, 24, 90, 0.55);
    --text-primary: white;
    --text-secondary: rgba(255, 255, 255, 0.92);
    --text-muted: rgba(255, 255, 255, 0.75);
    --text-accent: #1a7a6e;
    --border-light: rgba(255, 255, 255, 0.16);
    --border-lighter: rgba(255, 255, 255, 0.12);
    --brand-dark: #053063;
    --brand-light: #ffffff;
}

/* Default page theme variables and layout (moved from Default.aspx) */
:root[data-theme="dark"] {
    --bg: #0d0d0d;
    --bg2: #111;
    --card: #161616;
    --text: #fff;
    --text-muted: rgba(255,255,255,0.55);
    --text-faint: rgba(255,255,255,0.4);
    --border: rgba(255,255,255,0.08);
    --border-nav: rgba(255,255,255,0.12);
    --nav-bg: rgba(255,255,255,0.07);
    --marquee-border: rgba(255,255,255,0.06);
    --glow: rgba(26,122,110,0.2);
    --copyright: rgba(255,255,255,0.2);
}

:root[data-theme="light"] {
    --bg: #f5f5f5;
    --bg2: #ebebeb;
    --card: #fff;
    --text: #0a0a0a;
    --text-muted: rgba(0,0,0,0.6);
    --text-faint: rgba(0,0,0,0.45);
    --border: rgba(0,0,0,0.08);
    --border-nav: rgba(0,0,0,0.12);
    --nav-bg: rgba(0,0,0,0.06);
    --marquee-border: rgba(0,0,0,0.08);
    --glow: rgba(26,122,110,0.12);
    --copyright: rgba(0,0,0,0.3);
}

body {
    background: var(--bg);
    color: var(--text);
    transition: background 0.3s, color 0.3s;
}

.hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 3rem 2.5rem 4rem;
    min-height: 440px;
    position: relative;
    overflow: hidden;
}
.hero-glow {
    position: absolute;
    right: 220px;
    top: 50%;
    transform: translateY(-50%);
    width: 380px;
    height: 380px;
    background: radial-gradient(circle, var(--glow) 0%, transparent 70%);
    pointer-events: none;
}
.hero-left { flex: 1; z-index: 2; }
.hero-title {
    font-size: 72px;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 1rem;
}
.hero-divider { width: 80px; height: 2px; background: #1a7a6e; margin-bottom: 1.5rem; }
.hero-sub {
    font-size: 15px;
    color: var(--text-muted);
    max-width: 420px;
    line-height: 1.7;
    margin-bottom: 2rem;
}
.hero-btns { display: flex; gap: 12px; }
.btn-ghost {
    background: transparent;
    border: 1px solid var(--border-nav);
    color: var(--text);
    padding: 10px 24px;
    border-radius: 30px;
    font-size: 13px;
    cursor: pointer;
    letter-spacing: 0.05em;
    text-decoration: none;
    transition: all 0.2s;
}
.btn-teal {
    background: #1a7a6e;
    border: none;
    color: #fff;
    padding: 10px 24px;
    border-radius: 30px;
    font-size: 13px;
    cursor: pointer;
    letter-spacing: 0.05em;
    font-weight: 700;
    text-decoration: none;
}
.logo-display {
    width: 220px;
    height: 220px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid rgba(26,122,110,0.6);
    box-shadow: 0 0 50px rgba(26,122,110,0.25);
}
.logo-display img { width: 100%; height: 100%; object-fit: cover; display: block; }
.marquee-wrap {
    background: var(--bg2);
    border-top: 0.5px solid var(--marquee-border);
    border-bottom: 0.5px solid var(--marquee-border);
    padding: 14px 0;
    overflow: hidden;
    white-space: nowrap;
}
.marquee-track { display: inline-block; animation: marquee 22s linear infinite; }
.marquee-item {
    display: inline-block;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: #1a7a6e;
    margin: 0 2rem;
}
.marquee-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    background: var(--text-faint);
    border-radius: 50%;
    vertical-align: middle;
    margin: 0 0.5rem;
}
@keyframes marquee { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
.featured { padding: 3rem 2.5rem 2rem; }
.featured-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.25rem; }
.featured-header h2 { font-size: 20px; font-weight: 700; color: var(--text); }
.event-banner { background: var(--card); border: 0.5px solid var(--border); border-radius: 12px; }
.event-banner-inner { padding: 1.5rem 2rem; display: flex; align-items: center; justify-content: space-between; }
.event-tag {
    font-size: 11px;
    color: #1a7a6e;
    border: 0.5px solid rgba(26,122,110,0.5);
    padding: 3px 10px;
    border-radius: 4px;
    letter-spacing: 0.06em;
    display: inline-block;
    margin-bottom: 8px;
}
.event-banner h3 { font-size: 18px; font-weight: 600; color: var(--text); }
.event-date { font-size: 13px; color: var(--text-faint); margin-top: 4px; }
.stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; padding: 2rem 2.5rem 3rem; }
.stat-card { background: var(--card); border: 0.5px solid var(--border); border-radius: 12px; padding: 2rem 1.5rem; text-align: center; }
.stat-num { font-size: 48px; font-weight: 700; color: #1a7a6e; line-height: 1; }
.stat-label { font-size: 11px; letter-spacing: 0.1em; color: var(--text-faint); margin-top: 10px; }
.footer-tagline { padding: 2rem 2.5rem 1.5rem; border-top: 0.5px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
.footer-tagline h2 { font-size: 28px; font-weight: 700; color: var(--text); }
.footer-tagline h2 em { font-style: italic; color: #1a7a6e; }
.social-links { display: flex; gap: 16px; }
.social-links a { color: var(--text-faint); text-decoration: none; font-size: 22px; transition: color 0.2s; }
.copyright { text-align: right; padding: 0 2.5rem 1.5rem; font-size: 12px; color: var(--copyright); letter-spacing: 0.04em; }

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Segoe UI', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    transition: background 0.3s, color 0.3s;
}

.skip-link {
    position: absolute;
    left: -999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
}

    .skip-link:focus {
        position: absolute;
        left: 12px;
        top: 12px;
        width: auto;
        height: auto;
        padding: 8px 12px;
        background: var(--text-accent);
        color: var(--brand-dark);
        border-radius: 6px;
        z-index: 9999;
    }

.nav {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 12px 48px;
    background: rgba(255,255,255,0.03);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border-light);
}

.nav-brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 1.0rem;
    font-weight: 800;
    letter-spacing: 0.01em;
    color: var(--text-primary);
    text-decoration: none;
}

.nav-links-pill {
    display: flex;
    align-items: center;
    gap: 6px;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: 999px;
    padding: 6px 8px;
}

.nav-links-pill a {
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 700;
    font-size: 13px;
    padding: 8px 14px;
    border-radius: 20px;
    transition: color 0.12s ease, background 0.12s ease;
    display: inline-block;
    text-transform: uppercase;
}

.nav-links-pill a,
.nav-links-pill a:visited,
.nav-links-pill a:active {
    color: var(--text-primary);
}

.nav-links-pill a:hover,
.nav-links-pill a.active {
    color: var(--text-accent);
    background: rgba(26,122,110,0.04);
}

.nav .theme-toggle {
    margin-left: 12px;
}

@media (max-width: 900px) {
    .nav {
        padding: 10px 18px;
    }
    .nav-links-pill {
        display: none; /* hide pill on small screens; can be replaced with hamburger later */
    }
}

.theme-toggle {
    background: none;
    border: 2px solid var(--text-accent);
    color: var(--text-accent);
    padding: 8px 12px;
    border-radius: 6px;
    font-size: 1.2rem;
    cursor: pointer;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
}

    .theme-toggle:hover {
        background: var(--text-accent);
        color: var(--brand-dark);
    }

.site-footer {
    margin-top: auto;
    text-align: center;
    padding: 22px 12px;
    border-top: 1px solid var(--border-lighter);
    color: var(--text-secondary);
}

.page-header h1,
.hero h1,
.join-header h1 {
    font-size: 2.2rem;
    margin-bottom: 12px;
    line-height: 1.25;
}

.hero-kicker,
.kicker {
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 0.82rem;
    color: var(--text-accent);
    margin-bottom: 14px;
}

.cta-btn,
.ghost-btn {
    text-decoration: none;
    border-radius: 999px;
    padding: 11px 22px;
    font-weight: 700;
    font-size: 0.95rem;
    display: inline-block;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.cta-btn {
    background: var(--text-accent);
    color: var(--brand-dark);
    border: none;
}

.ghost-btn {
    border: 1px solid var(--text-accent);
    color: var(--text-accent);
    background: transparent;
}

main.page-content {
    width: min(1180px, 92%);
    margin: 40px auto 64px;
}

.hero,
.page-header,
.join-header {
    text-align: center;
} 
 
.hero {
    padding: 80px 22px 40px;
}

.hero-actions {
    margin-top: 28px;
    display: flex;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
}

.features,
.about-grid,
.events-grid,
.contact-layout,
.stats-grid,
.program-grid {
    display: grid;
    gap: 18px;
}

.features,
.about-grid,
.events-grid {
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    margin-top: 26px;
}

.feature-card,
.about-card,
.event-card,
.program-stats,
.form-wrapper,
.contact-panel {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 16px;
    padding: 22px;
    backdrop-filter: blur(8px);
}

.event-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.event-badge {
    align-self: flex-start;
    display: inline-flex;
    padding: 6px 10px;
    border-radius: 999px;
    background: var(--text-accent);
    color: var(--brand-dark);
    font-size: 0.82rem;
    font-weight: 700;
}

.event-meta {
    color: var(--text-muted);
    font-size: 0.92rem;
}

.contact-layout {
    grid-template-columns: minmax(240px, 340px) minmax(0, 1fr);
    align-items: start;
}

.contact-form-wrap,
.join-container,
.members-container {
    display: grid;
    gap: 22px;
}

.join-container {
    width: min(920px, 100%);
    margin: 0 auto;
}

.join-header p,
.page-header p,
.contact-panel p,
.about-card p,
.event-card p,
.feature-card p {
    line-height: 1.65;
}

.benefits-preview {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 14px;
    padding: 22px;
    border-radius: 16px;
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.34), rgba(118, 75, 162, 0.34));
    border: 1px solid rgba(255, 255, 255, 0.15);
}

.benefit-item {
    text-align: center;
}

.benefit-icon {
    font-size: 2.25rem;
    margin-bottom: 10px;
}

.info-box {
    padding: 16px 18px;
    border-radius: 12px;
    background: rgba(33, 150, 243, 0.14);
    border-left: 4px solid #2196f3;
    color: var(--text-primary);
}

.form-wrapper {
    padding: 28px;
}

.form-section {
    display: grid;
    gap: 14px;
    margin-bottom: 24px;
}

.form-grid,
.dashboard-actions,
.search-box,
.form-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
}

.two-columns {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 16px;
}

.form-field {
    display: grid;
    gap: 8px;
}

.text-input,
.text-area,
.search-input {
    width: 100%;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 12px;
    padding: 0.85rem 0.95rem;
    background: rgba(255, 255, 255, 0.06);
    color: var(--text-primary);
    font: inherit;
}

.text-area {
    min-height: 150px;
    resize: vertical;
}

.text-input::placeholder,
.text-area::placeholder,
.search-input::placeholder {
    color: var(--text-muted);
}

.program-list,
.checkbox-group {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
}

.program-list input,
.checkbox-group input {
    margin-right: 8px;
}

.program-list label,
.checkbox-group label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
}

.program-list td,
.checkbox-group td {
    padding: 0;
}

.program-list label,
.checkbox-group label,
.program-list input,
.checkbox-group input {
    cursor: pointer;
}

.program-list {
    padding: 0;
    margin: 0;
}

.form-actions {
    justify-content: flex-end;
    padding-top: 8px;
}

.single-action {
    justify-content: flex-start;
}

.btn-submit,
.btn-cancel,
.search-button {
    border: 0;
    border-radius: 999px;
    padding: 0.9rem 1.3rem;
    font-weight: 700;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
}

.btn-submit,
.search-button,
.cta-btn {
    background: var(--text-accent);
    color: var(--brand-dark);
}

.btn-cancel,
.ghost-btn {
    background: transparent;
    color: var(--text-accent);
    border: 1px solid var(--text-accent);
}

.btn-submit:hover,
.search-button:hover,
.cta-btn:hover,
.btn-cancel:hover,
.ghost-btn:hover {
    transform: translateY(-1px);
}

.validation-summary,
.field-validation-error {
    color: #ff9ea3;
    font-size: 0.9rem;
}

.validation-summary ul {
    margin: 0;
    padding-left: 18px;
}

.form-feedback {
    border-radius: 12px;
    padding: 14px 16px;
    margin-bottom: 18px;
}

.form-feedback.success {
    background: rgba(39, 174, 96, 0.18);
    border: 1px solid rgba(39, 174, 96, 0.4);
}

.form-feedback.error {
    background: rgba(231, 76, 60, 0.18);
    border: 1px solid rgba(231, 76, 60, 0.4);
}

.members-container {
    width: min(1120px, 100%);
    margin: 0 auto;
}

.dashboard-header {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 18px;
    flex-wrap: wrap;
}

.dashboard-actions .search-input {
    min-width: 240px;
}

.stats-grid {
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
}

.stat-card {
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.92), rgba(118, 75, 162, 0.92));
    color: #fff;
    padding: 1.5rem;
    border-radius: 16px;
    text-align: center;
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.15);
}

.stat-card .stat-value {
    font-size: 2rem;
    font-weight: 800;
    margin-top: 8px;
}

.program-stats {
    display: grid;
    gap: 16px;
}

.program-grid {
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
}

.program-item {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 14px;
    padding: 14px;
    text-align: center;
}

.program-name {
    font-weight: 700;
}

.program-count {
    margin-top: 8px;
    font-size: 1.6rem;
    color: var(--text-accent);
    font-weight: 800;
}

.members-list {
    display: grid;
    gap: 16px;
}

.member-card {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 16px;
    padding: 22px;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.1);
}

.member-header {
    display: flex;
    justify-content: space-between;
    gap: 14px;
    align-items: start;
    flex-wrap: wrap;
}

.member-email {
    color: var(--text-accent);
    text-decoration: none;
}

.member-meta {
    margin-top: 8px;
    color: var(--text-muted);
    font-size: 0.9rem;
}

.member-details {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 14px;
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid rgba(255, 255, 255, 0.14);
}

.detail-label {
    color: var(--text-muted);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 700;
}

.detail-value {
    margin-top: 6px;
}

.message-section {
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px solid rgba(255, 255, 255, 0.14);
}

.empty-state {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--text-muted);
}

.join-footer-note {
    text-align: center;
}

.join-footer-note a {
    color: var(--text-accent);
    font-weight: 700;
    text-decoration: none;
}

@media (max-width: 900px) {
    .contact-layout,
    .dashboard-header {
        grid-template-columns: 1fr;
    }

    .dashboard-header {
        align-items: start;
    }

    .navbar {
        padding: 18px 22px;
        flex-wrap: wrap;
        gap: 16px;
    }

    .nav-links {
        flex-wrap: wrap;
        gap: 16px;
    }
}

@media (max-width: 640px) {
    .hero {
        padding-top: 60px;
    }

    .form-wrapper,
    .feature-card,
    .about-card,
    .event-card,
    .member-card,
    .program-stats,
    .contact-panel {
        padding: 18px;
    }

    .btn-submit,
    .btn-cancel,
    .search-button,
    .cta-btn,
    .ghost-btn {
        width: 100%;
        justify-content: center;
        text-align: center;
    }

    .form-actions,
    .dashboard-actions,
    .search-box,
    .hero-actions {
        flex-direction: column;
    }
}